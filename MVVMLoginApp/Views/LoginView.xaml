<UserControl x:Class="MVVMLoginApp.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="#0A0A1A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Viewbox Grid.Column="1">
            <StackPanel Height="600">
                <TextBlock Text="Mawlers"
                    FontSize="52"
                    FontFamily="Impact"
                    FontWeight="Bold"
                    Foreground="#00AAFF"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,-5"/>
                <TextBlock Text="Cinema Complex"
                    FontSize="20"
                    FontWeight="Normal"
                    Foreground="#00FFFF"
                    FontFamily="Trebuchet MS"
                    HorizontalAlignment="Center"/>
                <TextBlock Text="Username"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="#00FFFF"
                    FontFamily="Trebuchet MS"
                    HorizontalAlignment="Center"
                    Margin="0,30,0,0"/>
                <TextBox Width="250"
                    Margin="0,5,0,10"
                    Background="#0F0F2A"
                    Foreground="#FFFFFF"
                    BorderBrush="#00FFFF"
                    BorderThickness="2"
                    Padding="5,8,5,8"
                    FontSize="14"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Password"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="#00FFFF"
                    FontFamily="Trebuchet MS"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0"/>
                <PasswordBox x:Name="PasswordInput"
                    Width="250"
                    Margin="0,5,0,10"
                    Background="#0F0F2A"
                    Foreground="#FFFFFF"
                    BorderBrush="#00FFFF"
                    BorderThickness="2"
                    Padding="5,8,5,8"
                    FontSize="14"/>
                <Button Content="Login"
                    Width="250"
                    Margin="0,20,0,0"
                    Background="#00AAFF"
                    Foreground="#FFFFFF"
                    FontFamily="Trebuchet MS"
                    FontSize="14"
                    FontWeight="Bold"
                    Padding="10,8,10,8"
                    BorderBrush="#00FFFF"
                    BorderThickness="2"
                    Command="{Binding LoginCommand}" Click="Button_Click"/>
                
            </StackPanel>
        </Viewbox>
    </Grid>
</UserControl>