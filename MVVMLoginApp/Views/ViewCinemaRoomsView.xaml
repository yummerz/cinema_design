<UserControl x:Class="MVVMLoginApp.Views.ViewCinemaRoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid Background="#0A0A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="10,10,10,0">
            <Button Content="Back to Main Menu"
                    Width="150" Height="30" HorizontalAlignment="Left"
                    Background="#0F0F2A" Foreground="#00FFFF"
                    FontFamily="Trebuchet MS" FontSize="12" FontWeight="Bold"
                    BorderBrush="#00FFFF" BorderThickness="2"
                    Command="{Binding BackToMainMenuCommand}"/>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Mawlers" FontSize="40" FontFamily="Impact"
                           FontWeight="Bold" Foreground="#00AAFF" HorizontalAlignment="Center"/>
                <TextBlock Text="Cinema Complex" FontSize="16" Foreground="#00FFFF"
                           FontFamily="Trebuchet MS" HorizontalAlignment="Center"/>
            </StackPanel>
            <Button Content="Logout"
                    Width="80" Height="30" HorizontalAlignment="Right"
                    Background="#0F0F2A" Foreground="#00FFFF"
                    FontFamily="Trebuchet MS" FontSize="12" FontWeight="Bold"
                    BorderBrush="#00FFFF" BorderThickness="2"
                    Command="{Binding LogoutCommand}"/>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Rooms List -->
            <Border Grid.Column="0" BorderBrush="#00FFFF" BorderThickness="2"
                    Margin="0,0,5,0" CornerRadius="4">
                <DockPanel Margin="8">
                    <TextBlock DockPanel.Dock="Top" Text="Cinema Rooms"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#00FFFF" Margin="0,0,0,8"/>
                    <ListView ItemsSource="{Binding Rooms}"
                              SelectedItem="{Binding SelectedRoom}"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Room Name" Width="200"
                                                DisplayMemberBinding="{Binding RoomName}"/>
                                <GridViewColumn Header="Capacity" Width="150"
                                                DisplayMemberBinding="{Binding Capacity}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- Room Form -->
            <Border Grid.Column="1" BorderBrush="#00FFFF" BorderThickness="2"
                    Margin="5,0,0,0" CornerRadius="4">
                <StackPanel Margin="12">
                    <TextBlock Text="{Binding FormTitle}" FontSize="18" FontWeight="Bold"
                               Foreground="#00FFFF" Margin="0,0,0,12"/>

                    <TextBlock Text="Room Name:" Foreground="#AAAAAA" FontSize="13"/>
                    <TextBox Margin="0,4,0,10" Padding="6,4"
                             Background="#0F0F2A" Foreground="White" BorderBrush="#00FFFF"
                             Text="{Binding RoomName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Capacity:" Foreground="#AAAAAA" FontSize="13"/>
                    <TextBox Margin="0,4,0,16" Padding="6,4"
                             Background="#0F0F2A" Foreground="White" BorderBrush="#00FFFF"
                             Text="{Binding Capacity, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Save" Width="70" Margin="0,0,6,0" Padding="0,6"
                                Background="#0F0F2A" Foreground="#00FFFF"
                                BorderBrush="#00FFFF" BorderThickness="2"
                                FontWeight="Bold" Command="{Binding SaveCommand}"/>
                        <Button Content="Update" Width="70" Margin="0,0,6,0" Padding="0,6"
                                Background="#0F0F2A" Foreground="#00FFFF"
                                BorderBrush="#00FFFF" BorderThickness="2"
                                FontWeight="Bold" Command="{Binding UpdateCommand}"/>
                        <Button Content="Delete" Width="70" Margin="0,0,6,0" Padding="0,6"
                                Background="#0F0F2A" Foreground="#00FFFF"
                                BorderBrush="#00FFFF" BorderThickness="2"
                                FontWeight="Bold" Command="{Binding DeleteCommand}"/>
                        <Button Content="Clear" Width="70" Padding="0,6"
                                Background="#0F0F2A" Foreground="#00FFFF"
                                BorderBrush="#00FFFF" BorderThickness="2"
                                FontWeight="Bold" Command="{Binding ClearCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>