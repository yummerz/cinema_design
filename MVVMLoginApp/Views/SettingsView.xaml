<UserControl x:Class="MVVMLoginApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is automatically set via DataTemplate in App.xaml -->
    <!-- Just bind directly to your ViewModel properties -->
    <Grid>
        <TextBlock Text="{Binding SomeValue}"/>
        <Button Content="Save"
                Command="{Binding SaveCommand}"/>
    </Grid>
</UserControl>