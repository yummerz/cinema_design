<Window x:Class="MVVMLoginApp.Views.temp"
        xmlns:vm="clr-namespace:MVVMLoginApp.ViewModels"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVMLoginApp.Views"
        mc:Ignorable="d"
        Title="temp" Height="450" Width="800">
    <Window.DataContext>
        <vm:LostItemViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
            BorderBrush="Gray"
            BorderThickness="1"
            Margin="5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
            Text="Lost Items"
            FontSize="20"
            FontWeight="Bold"
            Margin="10,5,0,5"/>
                <ListView BorderBrush="Gray" BorderThickness="1"
                    ItemsSource="{Binding LostItems}"
                    SelectedItem="{Binding SelectedItem}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="80" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Description" Width="150" DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Location Lost" Width="100" DisplayMemberBinding="{Binding LocationLost}"/>
                            <GridViewColumn Header="Date Reported" Width="100" DisplayMemberBinding="{Binding DateReported}"/>
                            <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status, Converter={StaticResource BoolToStatus}}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
         BorderBrush="Gray"
         BorderThickness="5"
         Margin="5">

            <StackPanel>
                <TextBlock Text="Report New lost Item" FontSize="20" FontWeight="Bold" Margin="10,5,0,0"/>
                <TextBlock Text="Name:" FontSize="15" Margin="5,10,0,0"/>
                <TextBox Margin="5,0,10,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Description:" FontSize="15" Margin="5,20,0,0"/>
                <TextBox Margin="5,0,10,0" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Location Lost:" FontSize="15" Margin="5,20,0,0"/>
                <TextBox Margin="5,0,10,0" Text="{Binding LocationLost, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Date Reported:" FontSize="15" Margin="5,20,0,0"/>
                <DatePicker Margin="5,0,10,0" SelectedDate="{Binding DateReported}"/>
                <CheckBox Content="Status" Margin="5,10,0,0" IsChecked="{Binding Status}"/>
                <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                    <Button Content="Save" Width="70" Margin="0,0,5,0" Command="{Binding SaveCommand}"/>
                    <Button Content="Delete" Width="70" Margin="0,0,5,0" Command="{Binding DeleteCommand}"/>
                    <Button Content="Clear" Width="70" Command="{Binding ClearCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
