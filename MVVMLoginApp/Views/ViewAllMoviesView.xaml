<UserControl x:Class="MVVMLoginApp.Views.ViewAllMoviesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="#0A0A1A">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" VerticalAlignment="Top">
                <TextBlock Text="Mawlers"
                       FontSize="52"
                       FontFamily="Impact"
                       FontWeight="Bold"
                       Foreground="#00AAFF"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,-5"/>
                <TextBlock Text="Cinema Complex"
                       FontSize="20"
                       FontWeight="Normal"
                       Foreground="#00FFFF"
                       FontFamily="Trebuchet MS"
                       HorizontalAlignment="Center"/>
            </StackPanel>
        </DockPanel>
        <Button Content="Back to Main Menu"
            Width="150" Height="30"
            HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="10,10,0,0"
            Background="#0F0F2A" Foreground="#00FFFF"
            FontFamily="Trebuchet MS" FontSize="12" FontWeight="Bold"
            BorderBrush="#00FFFF" BorderThickness="2"
            Command="{Binding BackToMainMenuCommand}"/>
        <Button Content="Logout"
            Width="80" Height="30"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,10,10,0"
            Background="#0F0F2A" Foreground="#00FFFF"
            FontFamily="Trebuchet MS" FontSize="12" FontWeight="Bold"
            BorderBrush="#00FFFF" BorderThickness="2"
            Command="{Binding LogoutCommand}"/>
    </Grid>
</UserControl>