<UserControl x:Class="MVVMLoginApp.Views.ScheduleaShowingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid Background="#0A0A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="10,10,10,0">
            <Button Content="Back to Main Menu"
                    Width="150" Height="30" HorizontalAlignment="Left"
                    Background="#0F0F2A" Foreground="#00FFFF"
                    FontFamily="Trebuchet MS" FontSize="12" FontWeight="Bold"
                    BorderBrush="#00FFFF" BorderThickness="2"
                    Command="{Binding BackToMainMenuCommand}"/>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Mawlers" FontSize="40" FontFamily="Impact"
                           FontWeight="Bold" Foreground="#00AAFF" HorizontalAlignment="Center"/>
                <TextBlock Text="Cinema Complex" FontSize="16" Foreground="#00FFFF"
                           FontFamily="Trebuchet MS" HorizontalAlignment="Center"/>
            </StackPanel>
            <Button Content="Logout"
                    Width="80" Height="30" HorizontalAlignment="Right"
                    Background="#0F0F2A" Foreground="#00FFFF"
                    FontFamily="Trebuchet MS" FontSize="12" FontWeight="Bold"
                    BorderBrush="#00FFFF" BorderThickness="2"
                    Command="{Binding LogoutCommand}"/>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Showings List -->
            <Border Grid.Column="0" BorderBrush="#00FFFF" BorderThickness="2"
                    Margin="0,0,5,0" CornerRadius="4">
                <DockPanel Margin="8">
                    <TextBlock DockPanel.Dock="Top" Text="All Showings"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#00FFFF" Margin="0,0,0,8"/>
                    <ListView ItemsSource="{Binding Showings}"
                              SelectedItem="{Binding SelectedShowing}"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Movie" Width="150"
                                                DisplayMemberBinding="{Binding MovieTitle}"/>
                                <GridViewColumn Header="Room" Width="100"
                                                DisplayMemberBinding="{Binding RoomName}"/>
                                <GridViewColumn Header="Date" Width="100"
                                                DisplayMemberBinding="{Binding ShowingDate, StringFormat=\{0:MM/dd/yyyy\}}"/>
                                <GridViewColumn Header="Time" Width="80"
                                                DisplayMemberBinding="{Binding ShowingTimeDisplay}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- Showing Form -->
            <Border Grid.Column="1" BorderBrush="#00FFFF" BorderThickness="2"
                    Margin="5,0,0,0" CornerRadius="4">
                <StackPanel Margin="12">
                    <TextBlock Text="{Binding FormTitle}" FontSize="18" FontWeight="Bold"
                               Foreground="#00FFFF" Margin="0,0,0,12"/>

                    <TextBlock Text="Select Movie:" Foreground="#AAAAAA" FontSize="13"/>
                    <ComboBox Margin="0,4,0,10" Padding="6,4"
                              Background="#000000" Foreground="#000000" BorderBrush="#00FFFF"
                              ItemsSource="{Binding Movies}"
                              SelectedItem="{Binding SelectedMovie}"
                              DisplayMemberPath="Title">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#000000"/>
                                <Setter Property="Foreground" Value="#00FFFF"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>

                    <TextBlock Text="Select Room:" Foreground="#AAAAAA" FontSize="13"/>
                    <ComboBox Margin="0,4,0,10" Padding="6,4"
                              Background="#000000" Foreground="#000000" BorderBrush="#00FFFF"
                              ItemsSource="{Binding Rooms}"
                              SelectedItem="{Binding SelectedRoom}"
                              DisplayMemberPath="RoomName">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#000000"/>
                                <Setter Property="Foreground" Value="#00FFFF"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>

                    <TextBlock Text="Date:" Foreground="#AAAAAA" FontSize="13"/>
                    <DatePicker Margin="0,4,0,10"
                        BorderBrush="#00FFFF"
                        SelectedDate="{Binding ShowingDate}">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Background" Value="#0F0F2A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="SelectionBrush" Value="#00FFFF"/>
                            </Style>
                        </DatePicker.Resources>
                        <DatePicker.CalendarStyle>
                            <Style TargetType="Calendar">
                                <Setter Property="Background" Value="#0F0F2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </DatePicker.CalendarStyle>
                    </DatePicker>

                    <TextBlock Text="Time (HH:MM):" Foreground="#AAAAAA" FontSize="13"/>
                    <TextBox Margin="0,4,0,16" Padding="6,4"
                             Background="#0F0F2A" Foreground="White" BorderBrush="#00FFFF"
                             Text="{Binding ShowingTime, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Save" Width="70" Margin="0,0,6,0" Padding="0,6"
                                Background="#0F0F2A" Foreground="#00FFFF"
                                BorderBrush="#00FFFF" BorderThickness="2"
                                FontWeight="Bold" Command="{Binding SaveCommand}"/>
                        <Button Content="Update" Width="70" Margin="0,0,6,0" Padding="0,6"
                                Background="#0F0F2A" Foreground="#00FFFF"
                                BorderBrush="#00FFFF" BorderThickness="2"
                                FontWeight="Bold" Command="{Binding UpdateCommand}"/>
                        <Button Content="Delete" Width="70" Margin="0,0,6,0" Padding="0,6"
                                Background="#0F0F2A" Foreground="#00FFFF"
                                BorderBrush="#00FFFF" BorderThickness="2"
                                FontWeight="Bold" Command="{Binding DeleteCommand}"/>
                        <Button Content="Clear" Width="70" Padding="0,6"
                                Background="#0F0F2A" Foreground="#00FFFF"
                                BorderBrush="#00FFFF" BorderThickness="2"
                                FontWeight="Bold" Command="{Binding ClearCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>